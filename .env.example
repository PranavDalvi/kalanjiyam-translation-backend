# Hugging Face Access Token for downloading gated models (e.g. indictrans2-en-indic-1B)
# Paste your token directly below (do not include the "token=" prefix or quotes)
HF_TOKEN=your_huggingface_token_here
GLOSSARIES_DIR=glossaries
# Max concurrent translation requests (to prevent CPU starvation under high concurrency)
MAX_CONCURRENT_TRANSLATIONS=2
# Auto-select the GPU with the most free memory (1 = enabled, 0 = disabled)
AUTO_SELECT_GPU=1

# API Key Authentication settings
# Enable/Disable API Key header check (1 = enabled, 0 = disabled)
ENABLE_API_KEY_AUTH=0
# Path to SQLite database storing hashed API keys
API_KEY_DB_PATH=api_keys.db
